{% extends 'base.html.twig' %}

{% block title %}今日の運航情報
{% endblock %}

{% block body %}
<main>
    <section id="operations-today">
        <h2>今日の運航情報</h2>

        {% if companies is not empty %}
            {% for company in companies %}
                <div class="company-section">
                    <h3 class="company-title">{{ company.name }}</h3>

                    {% if company.routes is not empty %}
                        <div class="route-cards-container">
                            {% for route in company.routes %}
                                <div class="route-card">
                                    <h4 class="route-title">{{ route.name }}</h4>
                                    {% if route.direction %}
                                        <p class="route-direction">{{ route.direction }}</p>
                                    {% endif %}

                                    {% set routeOps = operationsByRoute[route.id] ?? [] %}
                                    {% if routeOps is not empty %}
                                        {% for operation in routeOps %}
                                            <div class="operation-details">
                                                <span class="status {{ operation.status }}">{{ operation.getStatusText() }}</span>
                                                {% if operation.departureTime %}
                                                    <p>出発 {{ operation.departureTime|date('H:i') }}</p>
                                                {% endif %}
                                                {% if operation.arrivalTime %}
                                                    <p>到着 {{ operation.arrivalTime|date('H:i') }}</p>
                                                {% endif %}
                                                {% if operation.memo %}
                                                    <p class="operation-memo">備考: {{ operation.memo }}</p>
                                                {% endif %}
                                            </div>
                                        {% endfor %}
                                    {% else %}
                                        <p class="no-data">本日の運航情報なし</p>
                                    {% endif %}
                                </div>
                            {% endfor %}
                        </div>
                    {% else %}
                        <p class="no-data">このフェリー会社には登録された航路がありません。</p>
                    {% endif %}
                </div>
            {% endfor %}
        {% else %}
            <p class="no-data">本日の運航情報はありません。</p>
        {% endif %}
    </section>
</main>
{% endblock %}
