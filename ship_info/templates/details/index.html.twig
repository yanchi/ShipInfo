{% extends 'base.html.twig' %}

{% block title %}今日の運航情報
{% endblock %}

{% block body %}
<main>
    <section id="operations-today">
        <h2>今日の運航情報</h2>

        {% if companies is not empty %}
            {% for company in companies %}
                <div class="company-section">
                    <h3 class="company-title">フェリー会社: {{ company.name }}</h3>

                    {% if company.routes is not empty %}
                        <div class="route-cards-container">
                            {% for route in company.routes %}
                                <div class="route-card">
                                    <h4 class="route-title">航路: {{ route.name }}</h4>

                                    {% if route.operations is not empty %}
                                        {% for operation in route.operations %}
                                            <div class="operation-details">
                                                <p>運航日: {{ operation.operationDate|date('Y-m-d') }}</p>
                                                <p>方向: {{ route.direction }}</p>
                                                <p>状況: {{ operation.getStatusText() }}</p>{# operation.status_textで取れないため、アクセスメソット使用 #}
                                                <p>出発時刻: {{ operation.departureTime|date('H:i') }}</p>
                                                <p>到着時刻: {{ operation.arrivalTime|date('H:i') }}</p>
                                                <p>備考: {{ operation.memo }}</p>
                                            </div>
                                        {% endfor %}
                                    {% else %}
                                        <p class="no-data">この航路には本日の運航情報がありません。</p>
                                    {% endif %}
                                </div>
                            {% endfor %}
                        </div>
                    {% else %}
                        <p class="no-data">このフェリー会社には登録された航路がありません。</p>
                    {% endif %}
                </div>
            {% endfor %}
        {% else %}
            <p class="no-data">本日の運航情報はありません。</p>
        {% endif %}
    </section>
</main>
{% endblock %}
