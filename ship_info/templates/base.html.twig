<!DOCTYPE html>
<html lang="ja">
<head>
    <meta charset="UTF-8">
    <meta name="viewport" content="width=device-width, initial-scale=1.0">
    <title>{% block title %}フェリー運航情報サービス{% endblock %}</title>
    <link rel="stylesheet" href="{{ asset('/css/styles.css') }}">
    {% if app.environment == 'prod' and ga_measurement_id %}
        <!-- Google tag (gtag.js) -->
        <script async src="https://www.googletagmanager.com/gtag/js?id={{ ga_measurement_id }}"></script>
        <script>
            window.dataLayer = window.dataLayer || [];
            function gtag(){dataLayer.push(arguments);}
            gtag('js', new Date());
            gtag('config', '{{ ga_measurement_id }}');
        </script>
    {% endif %}
</head>
<body>
    <header>
        <h1>フェリー運航情報サービス</h1>
        <nav>
            <ul>
                <li><a href="{{ path('app_home') }}">ホーム</a></li>
                <li><a href="{{ path('app_details_today') }}">航路詳細</a></li>
                {# <li><a href="{{ path('app_contact') }}">お問い合わせ</a></li> #}
            </ul>
        </nav>
    </header>

    <main>
        {% block body %}{% endblock %}
    </main>

    <footer>
        <p>&copy; 2025 フェリー運航情報サービス</p>
    </footer>
</body>
</html>
