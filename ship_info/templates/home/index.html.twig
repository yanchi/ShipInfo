{% extends 'base.html.twig' %}

{% block title %}フェリー運航情報{% endblock %}

{% block body %}
<main>
    <section id="home">
        <h2>現在の運航状況</h2>
        {% if ship_data is not empty %}
            {% for ship in ship_data %}
            <div class="ferry-status">
                <h3>
                    {% if ship.url %}
                        <a href="{{ ship.url }}" target="_blank" rel="noopener noreferrer">{{ ship.name }}</a>
                    {% else %}
                        {{ ship.name }}
                    {% endif %}
                </h3>
                <ul>
                {% for route in ship.routes %}
                <li>{{ route.name }}:
                    {% for s in route.statuses %}
                        <span class="status {{ s.class ?: 'normal' }}">{{ s.text }}</span>
                    {% endfor %}
                </li>
                {% endfor %}
                </ul>
            </div>
            {% endfor %}
        {% else %}
            <p>現在、運航情報はありません。</p>
        {% endif %}
    </section>
</main>
{% endblock %}
