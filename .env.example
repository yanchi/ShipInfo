APP_ENV=prod
APP_SECRET=your_app_secret_here
MYSQL_HOST=db
MYSQL_ROOT_PASSWORD=your_root_password
MYSQL_DATABASE=ship_info
MYSQL_USER=user
MYSQL_PASSWORD=your_password
DATABASE_URL=mysql://user:your_password@db:3306/ship_info
MARIXLINE_SERVICE_URL=https://marixline.com/service/

# Nginx 配下で動かす場合
SYMFONY_BIND=127.0.0.1:8080

# メール通知設定 (非通常運航ステータス検出時)
SMTP_HOST=your_smtp_host
SMTP_PORT=587
SMTP_USER=your_smtp_user
SMTP_PASSWORD=your_smtp_password
NOTIFY_FROM=your_from_address
NOTIFY_TO=your_to_address
